# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bidforgood
DB_USER=bidforgood_app
DB_PASSWORD=your_password_here
# Set DB_SSL=true in production when connecting to a managed DB or TLS-enabled Postgres.
DB_SSL=false
# Only set this for a controlled emergency diagnostic. Production rejects DB_USER=postgres by default.
# ALLOW_SUPERUSER_DB=false

# Session JWT Configuration
# Used to sign HttpOnly cookie session tokens. Set this through GitHub/AWS secrets in production.
JWT_SECRET=replace_with_at_least_32_random_characters

# HTTPS / Proxy
# Production rejects plaintext requests unless this diagnostic flag is explicitly enabled.
ALLOW_INSECURE_HTTP=false

# Centralized failed-login tracking
# Required in production so credential-stuffing lockouts work across app instances.
LOGIN_ATTEMPT_CACHE=redis
REDIS_URL=redis://localhost:6379/0

# Internal security log sink for unhandled backend traces and cleanup failures.
SECURITY_LOG_FILE=./logs/security-events.jsonl

# Backup / Restore
BACKUP_DIR=./backups

# Seed passwords are never committed. Set these only when running seed scripts.
# SEED_ADMIN_PASSWORD=
# SEED_DEMO_PASSWORD=

# ── Email / SMTP2GO relay ──────────────────────────────────────────────────────
# Required in production. In dev/test the in-memory OTP stub is used instead.
SMTP2GO_USER=
SMTP2GO_PASS=

# Optional overrides (defaults shown)
# SMTP2GO_HOST=mail.smtp2go.com
# SMTP2GO_PORT=2525
# SMTP2GO_LOCAL_PORT=8888
# MAIL_EHLO_NAME=bidforgood.xyz
# MAIL_FROM_ADDRESS=noreply@bidforgood.xyz

# DKIM signing key — required in production. Point this at a path OUTSIDE the repo
# (e.g. a secrets volume, or the sibling nodejs_mail/dkim_private.pem during local testing).
# Never commit the key itself.
# DKIM_PRIVATE_KEY_PATH=
# DKIM_DOMAIN=bidforgood.xyz
# DKIM_SELECTOR=mail
