# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bidforgood
# The running app connects as a least-privilege role: DML only, no DDL, no superuser.
DB_USER=app_user
DB_PASSWORD=your_app_user_password_here

# Admin credentials — used only by the migrate/seed scripts, never by the running app.
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=your_postgres_password_here

# Session JWT Configuration
# Used to sign HttpOnly cookie session tokens. Set this through GitHub/AWS secrets in production.
JWT_SECRET=replace_with_at_least_32_random_characters

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Email / SMTP2GO relay ──────────────────────────────────────────────────────
# Required in production. In dev/test the in-memory OTP stub is used instead.
SMTP2GO_USER=
SMTP2GO_PASS=

# Optional overrides (defaults shown)
# SMTP2GO_HOST=mail.smtp2go.com
# SMTP2GO_PORT=2525
# SMTP2GO_LOCAL_PORT=8888
# MAIL_EHLO_NAME=bidforgood.xyz
# MAIL_FROM_ADDRESS=noreply@bidforgood.xyz

# DKIM signing key — required in production. Point this at a path OUTSIDE the repo
# (e.g. a secrets volume, or the sibling nodejs_mail/dkim_private.pem during local testing).
# Never commit the key itself.
# DKIM_PRIVATE_KEY_PATH=
# DKIM_DOMAIN=bidforgood.xyz
# DKIM_SELECTOR=mail
