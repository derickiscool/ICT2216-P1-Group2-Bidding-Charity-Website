# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use 'postgres' to use the Docker DB (preferred) or 'memory' to use an in-memory database
DATA_STORE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bidforgood
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Email / SMTP2GO relay ──────────────────────────────────────────────────────
# Required in production. In dev/test the in-memory OTP stub is used instead.
SMTP2GO_USER=
SMTP2GO_PASS=

# Optional overrides (defaults shown)
# SMTP2GO_HOST=mail.smtp2go.com
# SMTP2GO_PORT=2525
# SMTP2GO_LOCAL_PORT=8888
# MAIL_EHLO_NAME=bidforgood.xyz
# MAIL_FROM_ADDRESS=noreply@bidforgood.xyz

# DKIM signing key — required in production. Point this at a path OUTSIDE the repo
# (e.g. a secrets volume, or the sibling nodejs_mail/dkim_private.pem during local testing).
# Never commit the key itself.
# DKIM_PRIVATE_KEY_PATH=
# DKIM_DOMAIN=bidforgood.xyz
# DKIM_SELECTOR=mail