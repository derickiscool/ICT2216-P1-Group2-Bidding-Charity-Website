# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bidforgood
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Least-privilege role created by init/zz-app-user.sh and used by the backend at runtime.
# APP_DB_PASSWORD must match DB_PASSWORD in backend/.env.
APP_DB_USER=app_user
APP_DB_PASSWORD=your_app_user_password_here